{
  "fmt": {
    "include": [
      "src/",
      "*.ts",
      "*.tsx",
      "*.js",
      "*.jsx",
      "*.json",
      "*.md",
      "eslint.config.js",
      "vite.config.ts",
      "vitest.config.ts"
    ],
    "exclude": [
      "dist",
      "src-tauri/target",
      "src-tauri/gen",
      "node_modules",
      "pnpm-lock.yaml"
    ],
    "lineWidth": 100,
    "indentWidth": 2,
    "useTabs": false,
    "singleQuote": false,
    "semiColons": true,
    "proseWrap": "preserve"
  }
}
