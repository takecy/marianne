{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "core:window:allow-center",
    "dialog:allow-save",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "updater:default",
    "process:default"
  ]
}
