{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Marianne",
  "version": "0.1.0",
  "identifier": "dev.takecy.marianne",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Marianne",
        "width": 1280,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'"],
        "script-src": ["'self'"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "img-src": ["'self'", "data:", "blob:"],
        "font-src": ["'self'"],
        "connect-src": ["'self'", "ipc:", "http://ipc.localhost"],
        "media-src": ["'self'", "blob:"],
        "object-src": ["'none'"],
        "frame-src": ["'none'"],
        "base-uri": ["'self'"],
        "form-action": ["'none'"]
      },
      "devCsp": {
        "default-src": ["'self'"],
        "script-src": ["'self'"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "img-src": ["'self'", "data:", "blob:"],
        "font-src": ["'self'"],
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "ws://localhost:*",
          "http://localhost:*"
        ],
        "media-src": ["'self'", "blob:"],
        "object-src": ["'none'"],
        "frame-src": ["'none'"],
        "base-uri": ["'self'"],
        "form-action": ["'none'"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "category": "GraphicsAndDesign",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["icons/menubar.png"],
    "fileAssociations": [
      {
        "ext": ["png", "jpg", "jpeg"],
        "name": "Image",
        "description": "Image file supported by Marianne",
        "role": "Editor",
        "rank": "Default"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/takecy/marianne/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3ODM4NkQ1NTg1NUM0ODgKUldTSXhGVlkxWWFEaDZtcytEY3BQelVYZTF0MjBMa24vdWFMbDU3Y2RscUl1dWExejZSV3BLdjgK",
      "dialog": false,
      "windows": { "installMode": "passive" }
    }
  }
}
