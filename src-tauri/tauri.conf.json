{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Marianne",
  "version": "0.1.0",
  "identifier": "dev.takecy.marianne",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Marianne",
        "width": 1280,
        "height": 800,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "category": "GraphicsAndDesign",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["png", "jpg", "jpeg"],
        "name": "Image",
        "description": "Image file supported by Marianne",
        "role": "Editor",
        "rank": "Default"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/takecy/marianne/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZDNjA2MkQ3RkQ0QTJFRDcKUldUWExrcjkxMkpnYkhnMDhtbElpN3ozNGtCQkZxQXdMb1BuV1FSdjhTTUtMTzhlZWx3VlhWSUcK",
      "dialog": false,
      "windows": { "installMode": "passive" }
    }
  }
}
